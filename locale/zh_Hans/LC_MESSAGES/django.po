msgid "Simplified Chinese"
msgstr "简体中文"

msgid "English"
msgstr "英文"

msgid "Login"
msgstr "登录"

msgid "Show"
msgstr "显示"

msgid "Hide"
msgstr "隐藏"

msgid "Sign in"
msgstr "登录"

msgid "Welcome back"
msgstr "欢迎回来"

msgid "Enter your account details to continue your cute adventure."
msgstr "输入账号信息，继续你的可爱冒险。"

msgid "Username"
msgstr "用户名"

msgid "Enter your username"
msgstr "请输入用户名"

msgid "Password"
msgstr "密码"

msgid "Enter your password"
msgstr "请输入密码"

msgid "Remember me"
msgstr "记住我"

msgid "Username or password is incorrect."
msgstr "用户名或密码不正确。"

msgid "This account is inactive."
msgstr "当前账号不可用。"

msgid "Show password"
msgstr "显示密码"

msgid "Hide password"
msgstr "隐藏密码"

msgid "No account? Sign up"
msgstr "还没有账号？去注册"

msgid "Register"
msgstr "注册"

msgid "Create account"
msgstr "创建账号"

msgid "Already has account? Sign in"
msgstr "已有账号？去登录"

msgid "Email"
msgstr "邮箱"

msgid "Enter your email"
msgstr "请输入邮箱"

msgid "Verification code"
msgstr "验证码"

msgid "Enter verification code"
msgstr "请输入验证码"

msgid "Send code"
msgstr "发送验证码"

msgid "Resend in %(seconds)s s"
msgstr "%(seconds)s 秒后重发"

msgid "Confirm password"
msgstr "确认密码"

msgid "Enter your password again"
msgstr "请再次输入密码"

msgid "This username is already taken."
msgstr "该用户名已被占用。"

msgid "This email is already registered."
msgstr "该邮箱已被注册。"

msgid "Enter a valid 6-digit verification code."
msgstr "请输入有效的 6 位验证码。"

msgid "The two passwords do not match."
msgstr "两次输入的密码不一致。"

msgid "The verification code is invalid or expired."
msgstr "验证码无效或已过期。"

msgid "Registration is currently unavailable."
msgstr "当前暂不支持注册。"

msgid "Registration successful. Please sign in."
msgstr "注册成功，请登录。"

msgid "Email is required."
msgstr "请输入邮箱。"

msgid "Enter a valid email address."
msgstr "请输入有效的邮箱地址。"

msgid "Please wait before requesting another verification code."
msgstr "请稍后再请求新的验证码。"

msgid "Your registration verification code"
msgstr "注册验证码"

msgid "Your verification code is %(code)s. It will expire in %(minutes)s minutes."
msgstr "您的验证码是 %(code)s，将在 %(minutes)s 分钟后过期。"

msgid "[%(app_name)s] Your verification code"
msgstr "【%(app_name)s】验证码"

msgid "Verification Code"
msgstr "验证码"

msgid "Use the verification code below to complete your registration."
msgstr "请使用下方验证码完成注册。"

msgid "You are receiving this email because a registration verification code was requested for %(app_name)s."
msgstr "您收到这封邮件，是因为有人为 %(app_name)s 请求了注册验证码。"

msgid "One-time code"
msgstr "一次性验证码"

msgid "This code will expire in %(minutes)s minutes."
msgstr "该验证码将在 %(minutes)s 分钟后失效。"

msgid "For your security, do not forward this email or share the code with anyone."
msgstr "为保障您的账号安全，请勿转发此邮件或向任何人透露验证码。"

msgid "If you did not request this email, you can safely ignore it."
msgstr "如果这不是您的操作，您可以直接忽略这封邮件。"

msgid "This is an automated email from %(app_name)s. Please do not reply directly to this message."
msgstr "这是一封由 %(app_name)s 自动发送的邮件，请勿直接回复。"

msgid "%(app_name)s verification code"
msgstr "%(app_name)s 验证码"

msgid "Verification code sent."
msgstr "验证码已发送。"

msgid "Request failed."
msgstr "请求失败。"

msgid "Forgot password"
msgstr "忘记密码"

msgid "Password reset successful. Please check your email."
msgstr "密码重置成功，请检查邮箱。"

msgid "Password reset is currently unavailable."
msgstr "当前暂不支持密码重置。"

msgid "[%(app_name)s] Your temporary password"
msgstr "【%(app_name)s】临时密码"

msgid "Temporary Password"
msgstr "临时密码"

msgid "Use the temporary password below to sign in to your account."
msgstr "请使用下方临时密码登录您的账号。"

msgid "A password reset request was processed for your %(app_name)s account."
msgstr "系统已为您的 %(app_name)s 账号处理了一次密码重置请求。"

msgid "Temporary password"
msgstr "临时密码"

msgid "For security, please sign in as soon as possible and change this password immediately."
msgstr "为了您的账号安全，请尽快登录并立即修改该密码。"

msgid "If you did not request this reset, please contact an administrator after signing in."
msgstr "如果这不是您的操作，请在登录后尽快联系管理员。"

msgid "%(app_name)s temporary password"
msgstr "%(app_name)s 临时密码"

msgid "Close"
msgstr "关闭"

msgid "Password Reset"
msgstr "密码重置"

msgid "Password Reset Unavailable"
msgstr "密码重置不可用"

msgid "OK"
msgstr "确定"
